# ── Local development (docker compose) ──────────────────────────────────────
# Copy this file to .env and fill in values for local dev.
# .env is gitignored — never commit real secrets.

AWS_DEFAULT_REGION=us-east-1

# LocalStack fakes AWS locally — any value works for credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# SQS — LocalStack uses account ID 000000000000
SQS_QUEUE_URL=http://localhost:4566/000000000000/betops-queue

# Database — matches docker-compose.yml defaults
DB_HOST=localhost
DB_PORT=5432
DB_NAME=betops
DB_USER=betops
DB_PASSWORD=betops

# ── Real AWS deployment (set in GitHub Actions secrets / Lambda env vars) ────
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:betops/db-credentials
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/betops-queue
